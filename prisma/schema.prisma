// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())
  username String? @unique
  email String? @unique
  steamId String? @unique
  password String?
  avatar String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs Log[]
  reviews Review[]
}

model Game {
  id String @id @default(cuid())
  steamAppId Int @unique
  name String
  imageUrl String?
  description String? @db.Text
  developers String?
  genres String?
  publisher String?
  steamRating String?
  isStub Boolean @default(true) // Untuk lazy import
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs Log[]
  reviews Review[]
}

model Log {
  id String @id @default(cuid())
  userId String
  gameId String
  playtimeForever Int
  lastSyncedAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])
  @@unique([userId, gameId]) // Satu user cuma punya satu log per game
}

model Review {
  id String @id @default(cuid())
  userId String
  gameId String
  rating Int
  content String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  @@unique([userId, gameId]) // Satu user cuma boleh review satu kali per game
}
